# ProofVault — root environment template
# Copy to .env.local and fill in actual values. .env.local is gitignored.
# Per-app overrides live in apps/*/.env.local once those apps are scaffolded.

# -----------------------------------------------------------------------------
# Midnight network endpoints
# Default values point at the local-dev Docker stack (see SETUP.md §5).
# For the demo, swap to the Preprod URLs (commented below).
# -----------------------------------------------------------------------------
MIDNIGHT_NETWORK_ID=Undeployed
MIDNIGHT_NODE_URL=http://localhost:9944
MIDNIGHT_INDEXER_URL=http://localhost:8088/api/v3/graphql
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300

# Preprod (uncomment + comment-out the local URLs above when demoing):
# MIDNIGHT_NETWORK_ID=TestNet
# MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network
# MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v3/graphql
# MIDNIGHT_PROOF_SERVER_URL=https://proof-server.preprod.midnight.network
# NOTE: Preprod URLs above are best-guess pattern — verify against current
# Midnight docs (https://docs.midnight.network) before relying on them.

# -----------------------------------------------------------------------------
# Demo wallet (Lace 2.0 — hackathon throwaway, Preprod only)
# Three address types: shielded (ZK/contract), unshielded (chain/faucet), dust.
# -----------------------------------------------------------------------------
DEMO_WALLET_SHIELDED_ADDRESS=mn_shield-addr_preprod1...
DEMO_WALLET_UNSHIELDED_ADDRESS=mn_addr_preprod1...
DEMO_WALLET_DUST_ADDRESS=mn_dust_preprod1...

# -----------------------------------------------------------------------------
# Plaid sandbox (apps/attestor-backend) — fill after dashboard.plaid.com signup
# -----------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=auth,transactions
PLAID_COUNTRY_CODES=US

# -----------------------------------------------------------------------------
# Attestor backend runtime
# -----------------------------------------------------------------------------
ATTESTOR_PORT=4000
ATTESTOR_PUBLIC_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Prover-app (Next.js) — vars prefixed NEXT_PUBLIC_* are inlined into the
# browser bundle. Keep secrets out of these.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ATTESTOR_URL=http://localhost:4000
# Origin of the verifier portal (used by the prover-app to build the
# /verify/{proofId} URL shown on the result card). Leave blank to use a
# same-origin relative URL.
NEXT_PUBLIC_VERIFIER_BASE_URL=http://localhost:3001
